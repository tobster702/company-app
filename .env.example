# ResumeRocket configuration — copy to `.env.local` for local dev,
# and set these as environment variables / secrets on the deploy host.

# Required in production: your Anthropic API key. Powers the AI pipeline.
# Without it (and without RESUME_DEMO_MODE), /api/generate returns 503.
ANTHROPIC_API_KEY=

# Optional: override the model. Defaults to claude-opus-4-8 (most capable).
# Set to claude-sonnet-4-6 to cut per-pack cost ~5x if quality holds up.
# RESUME_MODEL=claude-opus-4-8

# Optional: set to 1 to return a clearly-labeled DEMO pack without calling the
# API (for local UI work / CI smoke tests). Never set this in production.
# RESUME_DEMO_MODE=0
